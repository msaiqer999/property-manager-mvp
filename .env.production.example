APP_NAME="Property Manager"
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_GENERATED_APP_KEY
APP_DEBUG=false
APP_URL=https://property-manager.example.com
APP_TIMEZONE=Asia/Dubai
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
REGISTRATION_ENABLED=false

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres.example.internal
DB_PORT=5432
DB_DATABASE=property_manager_pilot
DB_USERNAME=property_manager_app
DB_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=true
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
PRIVATE_DOCUMENTS_DISK=s3
UNIT_DOCUMENTS_DISK=
AWS_ACCESS_KEY_ID=REPLACE_WITH_OBJECT_STORAGE_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_OBJECT_STORAGE_SECRET_KEY
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=REPLACE_WITH_PRIVATE_DOCUMENT_BUCKET
AWS_URL=
AWS_ENDPOINT=REPLACE_WITH_S3_COMPATIBLE_ENDPOINT
AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=REPLACE_WITH_SMTP_USERNAME
MAIL_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
MAIL_FROM_ADDRESS="no-reply@property-manager.example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Replace every REPLACE_* placeholder before deployment.
# Do not commit real secrets, real database passwords, SMTP credentials, or a live domain.
# The PostgreSQL database user must be a least-privilege application user, not a PostgreSQL superuser.
# Password-reset email requires working SMTP configuration.
